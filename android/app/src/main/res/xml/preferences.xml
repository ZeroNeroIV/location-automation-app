<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="General">

        <SwitchPreferenceCompat
            app:key="notifications_enabled"
            app:title="Notifications"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="sound_enabled"
            app:title="Sound"
            app:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory app:title="Detection">

        <Preference
            app:key="detection_priority"
            app:title="Priority"
            app:summary="Current: High"
            app:defaultValue="High" />

        <EditTextPreference
            app:key="debounce_time"
            app:title="Debounce Time (seconds)"
            app:defaultValue="30"
            app:inputType="number" />

    </PreferenceCategory>

    <PreferenceCategory app:title="Learning">

        <SwitchPreferenceCompat
            app:key="learning_enabled"
            app:title="Enable Learning"
            app:defaultValue="true" />

        <Preference
            app:key="clear_learning_data"
            app:title="Clear Learning Data"
            app:summary="Remove all stored learning patterns" />

    </PreferenceCategory>

    <PreferenceCategory app:title="About">

        <Preference
            app:key="app_version"
            app:title="Version"
            app:summary="Version 1.0.0"
            app:selectable="false" />

    </PreferenceCategory>

</PreferenceScreen>