<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/activeIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/active_indicator"
            app:layout_constraintBottom_toBottomOf="@id/zoneName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/zoneName" />

        <TextView
            android:id="@+id/zoneName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="#212121"
            app:layout_constraintEnd_toStartOf="@id/zoneInfo"
            app:layout_constraintStart_toEndOf="@id/activeIndicator"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Home Zone" />

        <TextView
            android:id="@+id/profileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="#757575"
            app:layout_constraintEnd_toStartOf="@id/zoneInfo"
            app:layout_constraintStart_toEndOf="@id/activeIndicator"
            app:layout_constraintTop_toBottomOf="@id/zoneName"
            tools:text="Profile: Quiet Mode" />

        <TextView
            android:id="@+id/zoneInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="#9E9E9E"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="100m" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>