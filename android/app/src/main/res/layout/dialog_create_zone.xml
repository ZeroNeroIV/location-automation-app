<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/zoneNameLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Zone Name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/zoneNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/zoneRadiusLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Radius (meters)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/zoneRadiusInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Profile"
        android:textColor="@color/on_surface"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <RadioGroup
        android:id="@+id/profileGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/profileNormal"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Normal - Ring &amp; Vibrate"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/profileSilent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Silent - No ring, no vibrate"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/profileVibrate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Vibrate Only"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/profileDnd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Do Not Disturb"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

    </RadioGroup>

</LinearLayout>